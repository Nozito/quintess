# Base de données — Supabase (production / Vercel)
# Transaction pooler (serverless-friendly)
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-eu-north-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Base de données — PostgreSQL local (développement)
# DATABASE_URL="postgresql://postgres@localhost:5432/quintess"

# Auth JWT — générer avec : openssl rand -base64 32
AUTH_SECRET="votre-secret-aleatoire-minimum-32-caracteres"

NODE_ENV="development"
